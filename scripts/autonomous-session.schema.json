{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AutonomousSessionResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "tests_run"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "done",
        "blocked",
        "needs_input",
        "failed"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "tests_run": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
